      "targetHandle": "input"
    },
    {
      "id": "e-parse-extractisdone",
      "source": "parse-response",
      "sourceHandle": "output",
      "target": "extract-isdone",
      "targetHandle": "input"
    },
    {
      "id": "e-extractisdone-checkdone",
      "source": "extract-isdone",
      "sourceHandle": "output",
      "target": "check-done",
      "targetHandle": "input"
    },
    {
      "id": "e-parse-finalresult",
      "source": "parse-response",
      "sourceHandle": "output",
      "target": "extract-final-result",
      "targetHandle": "input"
    },
    {
      "id": "e-parse-action",
      "source": "parse-response",
      "sourceHandle": "output",
      "target": "extract-action",
      "targetHandle": "input"
    },
    {
      "id": "e-parse-selector",
      "source": "parse-response",
      "sourceHandle": "output",
      "target": "extract-selector",
      "targetHandle": "input"
    },
    {
      "id": "e-parse-value",
      "source": "parse-response",
      "sourceHandle": "output",
      "target": "extract-value",
      "targetHandle": "input"
    },
    {
      "id": "e-action-execute",
      "source": "extract-action",
      "sourceHandle": "output",
      "target": "execute-action",
      "targetHandle": "action"
    },
    {
      "id": "e-selector-execute",
      "source": "extract-selector",
      "sourceHandle": "output",
      "target": "execute-action",
      "targetHandle": "selector"
    },
    {
      "id": "e-value-execute",
