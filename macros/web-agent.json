      "targetHandle": "value"
    },
    {
      "id": "e-session-execute",
      "source": "browser-session",
      "sourceHandle": "session",
      "target": "execute-action",
      "targetHandle": "session"
    },
    {
      "id": "e-execute-updatehistory",
      "source": "execute-action",
      "sourceHandle": "result",
      "target": "update-history",
      "targetHandle": "input"
    },
    {
      "id": "e-parse-updatehistory",
      "source": "parse-response",
      "sourceHandle": "output",
      "target": "update-history",
      "targetHandle": "input2"
    },
    {
      "id": "e-readhistory-updatehistory",
      "source": "read-history",
      "sourceHandle": "value",
      "target": "update-history",
      "targetHandle": "input3"
    },
    {
      "id": "e-updatehistory-save",
      "source": "update-history",
