{
  "version": "1.0",
  "id": "flow-browser-demo",
  "name": "Browser Echo Demo",
  "description": "Test custom headers with the echo endpoint",
  "tags": [
    "browser",
    "desktop-only"
  ],
  "createdAt": "2026-01-14T23:46:24.343Z",
  "updatedAt": "2026-01-14T23:46:24.343Z",
  "nodes": [
    {
      "id": "browser-session",
      "type": "browser_session",
      "position": {
        "x": 100,
        "y": 150
      },
      "data": {
        "profile": "chrome_windows"
      }
    },
    {
      "id": "browser-request",
      "type": "browser_request",
      "position": {
        "x": 450,
        "y": 100
      },
      "data": {
        "method": "POST",
        "url": "http://localhost:3456/api/echo",
        "bodyType": "json",
        "body": "{\"message\": \"Hello from Zipp Desktop!\", \"test\": true}",
        "customHeaders": "{\n  \"X-Custom-Header\": \"ZippDesktop\",\n  \"X-Request-Source\": \"workflow-demo\"\n}",
        "responseFormat": "json",
        "followRedirects": true,
        "maxRedirects": 5
      }
    },
    {
      "id": "extract-header",
      "type": "browser_extract",
      "position": {
        "x": 850,
        "y": 100
      },
      "data": {
        "extractionType": "regex",
        "pattern": "\"x-custom-header\":\\s*\"([^\"]+)\"",
        "outputFormat": "first"
      }
    },
    {
      "id": "extract-source",
      "type": "browser_extract",
      "position": {
        "x": 850,
        "y": 250
      },
      "data": {
        "extractionType": "regex",
        "pattern": "\"x-request-source\":\\s*\"([^\"]+)\"",
        "outputFormat": "first"
      }
    },
    {
      "id": "format-result",
      "type": "template",
      "position": {
        "x": 1150,
        "y": 150
      },
      "data": {
        "template": "Echo Demo Complete!\\n\\nServer received your custom headers:\\n- X-Custom-Header: {{header}}\\n- X-Request-Source: {{source}}\\n\\nThis demonstrates:\\n- Custom headers work correctly\\n- JSON body posting\\n- Response extraction with regex",
        "inputCount": 2,
        "inputNames": [
          "header",
          "source"
        ]
      }
    },
    {
      "id": "output-result",
      "type": "output",
      "position": {
        "x": 1450,
        "y": 150
      },
      "data": {
        "label": "result"
      }
    }
  ],
  "edges": [
    {
      "source": "browser-session",
      "target": "browser-request",
      "targetHandle": "session",
      "id": "e-0-1768434384343"
    },
    {
      "source": "browser-request",
      "target": "extract-header",
      "id": "e-1-1768434384343"
    },
    {
      "source": "browser-request",
      "target": "extract-source",
      "id": "e-2-1768434384343"
    },
    {
      "source": "extract-header",
      "target": "format-result",
      "targetHandle": "header",
      "id": "e-3-1768434384343"
    },
    {
      "source": "extract-source",
      "target": "format-result",
      "targetHandle": "source",
      "id": "e-4-1768434384343"
    },
    {
      "source": "format-result",
      "target": "output-result",
      "id": "e-5-1768434384343"
    }
  ]
}