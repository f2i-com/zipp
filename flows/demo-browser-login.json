      "source": "session",
      "target": "dashboard-request",
      "targetHandle": "session",
      "id": "e-1-1768434384343"
    },
    {
      "source": "input-username",
      "target": "template-login-body",
      "targetHandle": "username",
      "id": "e-2-1768434384343"
    },
    {
      "source": "input-password",
      "target": "template-login-body",
      "targetHandle": "password",
      "id": "e-3-1768434384343"
    },
    {
      "source": "template-login-body",
      "target": "login-request",
      "targetHandle": "body",
      "id": "e-4-1768434384343"
    },
    {
      "source": "login-request",
      "target": "extract-login",
      "id": "e-5-1768434384343"
    },
    {
      "source": "extract-login",
      "target": "dashboard-request",
