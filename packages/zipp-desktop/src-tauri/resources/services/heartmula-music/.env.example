# HeartMuLa Music Generation Server Configuration

# Server settings
HEARTMULA_HOST=127.0.0.1
HEARTMULA_PORT=8767

# Device settings
HEARTMULA_DEVICE=cuda
HEARTMULA_DEVICE_ID=0

# Model paths (leave empty for auto-download from HuggingFace)
HEARTMULA_MODEL_PATH=
HEARTMULA_CODEC_PATH=
HEARTMULA_TOKENIZER_PATH=

# Output directory (leave empty for system temp)
HEARTMULA_OUTPUT_DIR=

# Float8 quantization (set to false to use full precision)
HEARTMULA_USE_FP8=true
