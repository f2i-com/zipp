# ACE-Step Music Generation Server Configuration

# Server host and port
ACESTEP_HOST=127.0.0.1
ACESTEP_PORT=8766

# Device: cuda or cpu
ACESTEP_DEVICE=cuda
ACESTEP_DEVICE_ID=0

# Use bfloat16 precision (recommended for CUDA, set to false for CPU/Mac)
ACESTEP_BF16=true

# Enable torch.compile optimization (faster but slower startup)
ACESTEP_TORCH_COMPILE=false

# Enable CPU offload to reduce VRAM usage (for GPUs with <12GB VRAM)
ACESTEP_CPU_OFFLOAD=false

# Custom checkpoint path (empty = auto-download to ~/.cache/ace-step/checkpoints)
ACESTEP_CHECKPOINT_PATH=

# Output directory for generated audio (empty = system temp)
ACESTEP_OUTPUT_DIR=
