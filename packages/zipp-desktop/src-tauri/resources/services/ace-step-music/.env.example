# ACE-Step 1.5 Music Generation Server Configuration

# Server host and port
ACESTEP_HOST=127.0.0.1
ACESTEP_PORT=8766

# Device: cuda or cpu
ACESTEP_DEVICE=cuda
ACESTEP_DEVICE_ID=0

# Use bfloat16 precision (recommended for CUDA, set to false for CPU/Mac)
ACESTEP_BF16=true

# Enable torch.compile optimization (faster but slower startup)
ACESTEP_TORCH_COMPILE=false

# Enable CPU offload to reduce VRAM usage (for GPUs with <8GB VRAM)
ACESTEP_CPU_OFFLOAD=false

# Enable overlapped decoding for faster inference (recommended)
ACESTEP_OVERLAPPED_DECODE=true

# Enable quantization for lower VRAM usage (auto-detected if FP8 model present)
# Leave commented to auto-detect, or set explicitly to override
# ACESTEP_QUANTIZED=true

# Model variant: base, sft, or turbo (turbo is fastest, 8 steps)
ACESTEP_MODEL_VARIANT=turbo

# Custom checkpoint path (empty = use ACE-Step/Ace-Step1.5 from HuggingFace)
# For FP8 quantized: manually download rolex0775/ace_step_1.5_turbo_aio_fp8 and set path here
# Model downloads to cache on first use
ACESTEP_CHECKPOINT_PATH=

# Output directory for generated audio (empty = system temp)
ACESTEP_OUTPUT_DIR=
