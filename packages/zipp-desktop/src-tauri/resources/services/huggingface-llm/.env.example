# HuggingFace LLM Service Configuration
HF_LLM_HOST=127.0.0.1
HF_LLM_PORT=8774

# Device: cuda, cpu, mps (auto-detected if empty)
# HF_LLM_DEVICE=

# Default model to load on startup
# Supports: HuggingFace model ID, local directory, or .gguf file path
#
# HuggingFace models (auto-downloaded):
#   Qwen/Qwen2.5-7B-Instruct
#   meta-llama/Llama-3.1-8B-Instruct
#   microsoft/Phi-3.5-mini-instruct
#   mistralai/Mistral-7B-Instruct-v0.3
# Vision models (support images):
#   Qwen/Qwen2.5-VL-7B-Instruct
#   meta-llama/Llama-3.2-11B-Vision-Instruct
# GGUF from HuggingFace (auto-downloaded):
#   unsloth/Qwen3.5-9B-GGUF/Qwen3.5-9B-Q4_K_M.gguf
# Local .gguf files:
#   C:/models/qwen2.5-7b-instruct-q4_k_m.gguf
# Local safetensors directory:
#   C:/models/my-finetuned-model/
HF_LLM_DEFAULT_MODEL=Qwen/Qwen3.5-9B

# Quantization: none, 4bit, 8bit (4bit recommended for <12GB VRAM)
HF_LLM_QUANTIZE=4bit

# Maximum new tokens to generate (0 = model default, typically 2048)
HF_LLM_MAX_NEW_TOKENS=2048

# HuggingFace token for gated models (Llama, Gemma, etc.)
# Get yours at https://huggingface.co/settings/tokens
# HF_TOKEN=

# Models cache directory (default: HuggingFace default cache)
# HF_HOME=./models
