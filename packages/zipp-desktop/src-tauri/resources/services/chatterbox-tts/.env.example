# Chatterbox TTS Server Configuration

# Server host and port
CHATTERBOX_HOST=127.0.0.1
CHATTERBOX_PORT=8765

# Device: cuda, cpu, or mps (for Apple Silicon)
# Leave empty for auto-detection
CHATTERBOX_DEVICE=cuda

# Model type: turbo, standard, or multilingual
# - turbo: Fastest, best for real-time applications
# - standard: Original Chatterbox model
# - multilingual: Supports 23 languages
CHATTERBOX_MODEL_TYPE=turbo

# Output directory for generated audio files
# Leave empty for system temp directory
CHATTERBOX_OUTPUT_DIR=

# Default generation parameters (for standard model)
CHATTERBOX_EXAGGERATION=0.5
CHATTERBOX_CFG_WEIGHT=0.5
