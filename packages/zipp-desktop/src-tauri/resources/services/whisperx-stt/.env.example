# WhisperX Speech-to-Text Server Configuration

# Server settings
WHISPERX_HOST=127.0.0.1
WHISPERX_PORT=8770

# Model settings
# Available models: tiny, base, small, medium, large-v2, large-v3
WHISPERX_MODEL=large-v3

# Compute type: float16 (GPU), int8 (CPU), float32 (fallback)
WHISPERX_COMPUTE_TYPE=float16

# Device: cuda, cpu
WHISPERX_DEVICE=cuda

# Batch size for processing (reduce if out of memory)
WHISPERX_BATCH_SIZE=16

# HuggingFace token for speaker diarization (optional)
# Get token from https://huggingface.co/settings/tokens
# Required for speaker diarization feature
HF_TOKEN=

# Output directory for temporary files
WHISPERX_OUTPUT_DIR=
