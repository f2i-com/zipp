# Qwen3 TTS Server Configuration

# Server host and port
QWEN3_HOST=127.0.0.1
QWEN3_PORT=8772

# Device: cuda, cpu, or mps (for Apple Silicon)
# Leave empty for auto-detection (recommended)
QWEN3_DEVICE=

# Model type: custom_voice or voice_design
# - custom_voice: Use predefined speakers (Vivian, Ryan, etc.)
# - voice_design: Design custom voices with descriptions
QWEN3_MODEL_TYPE=custom_voice

# Default speaker for CustomVoice mode
# Available: Vivian, Serena, Uncle_Fu, Dylan, Eric, Ryan, Aiden, Ono_Anna, Sohee
QWEN3_DEFAULT_SPEAKER=Vivian

# Output directory for generated audio files
# Leave empty for system temp directory
QWEN3_OUTPUT_DIR=
