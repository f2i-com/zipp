# Wan2GP Service Configuration
WAN2GP_HOST=127.0.0.1
WAN2GP_PORT=8773

# Internal Gradio port (Wan2GP's own UI)
WAN2GP_GRADIO_PORT=7870

# Wan2GP repository path (cloned automatically on first run)
# WAN2GP_PATH=./Wan2GP

# GPU profile (1-5, default 4 = aggressive offloading for low VRAM)
WAN2GP_PROFILE=4

# Attention implementation: sdpa, flash, sage, sage2
WAN2GP_ATTENTION=sdpa

# Default models
WAN2GP_DEFAULT_IMAGE_MODEL=qwen
WAN2GP_DEFAULT_VIDEO_MODEL=ltx2_22B
WAN2GP_DEFAULT_LLM_MODEL=qwen3.5

# Output directory
WAN2GP_OUTPUT_DIR=./outputs
