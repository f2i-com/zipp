{
    "id": "video_gen",
    "name": "Video Gen",
    "description": "Generate videos using Wan2GP or ComfyUI workflows.",
    "doc": "Generate AI videos from prompts or images.\n\nSupported Backends:\n• Wan2GP (LTX Video, Wan, Hunyuan - local)\n• ComfyUI (custom workflows)\n\nModes:\n• Text-to-video: Describe what you want\n• Image-to-video: Animate a source image\n\nSettings:\n• Frame Count - number of frames to generate\n• Width/Height - video dimensions\n• Frame Rate - output FPS\n\nTip: Use 'Free Memory' node before video generation to prevent out-of-memory errors.",
    "icon": "video",
    "color": "orange",
    "tags": [
        "video",
        "generate",
        "ai",
        "comfyui"
    ],
    "flowplan": {
        "stepTypes": [
            "video_gen"
        ],
        "fieldMapping": {
            "prompt": "prompt"
        },
        "literalInputFields": [
            "prompt"
        ],
        "templateFields": [
            "prompt"
        ],
        "inputHandleMapping": {
            "prompt": "prompt"
        }
    },
    "inputs": [
        {
            "id": "prompt",
            "name": "Prompt",
            "type": "string",
            "position": "left",
            "required": false,
            "description": "Video generation prompt"
        },
        {
            "id": "image",
            "name": "Image",
            "type": "image",
            "position": "left",
            "required": false,
            "description": "Start image for img2vid generation"
        },
        {
            "id": "image_end",
            "name": "End Image",
            "type": "image",
            "position": "left",
            "required": false,
            "description": "End image for video generation (optional)"
        },
        {
            "id": "frameCount",
            "name": "Frame Count",
            "type": "number",
            "position": "left",
            "required": false,
            "description": "Number of frames (overrides workflow default)"
        },
        {
            "id": "audio",
            "name": "Audio",
            "type": "audio",
            "position": "left",
            "required": false,
            "description": "Audio input for audio-guided video generation (LTX 2.3, etc.)"
        }
    ],
    "outputs": [
        {
            "id": "video",
            "name": "Video",
            "type": "video",
            "position": "right",
            "description": "Generated video URL/Path"
        }
    ],
    "properties": [
        {
            "id": "apiFormat",
            "name": "Backend",
            "type": "select",
            "default": "comfyui",
            "options": [
                { "value": "comfyui", "label": "ComfyUI" },
                { "value": "wan2gp", "label": "Wan2GP (LTX/Wan/Hunyuan)" }
            ],
            "description": "Video generation backend"
        },
        {
            "id": "wan2gpModel",
            "name": "Wan2GP Model",
            "type": "select",
            "default": "ltx2_22B_distilled",
            "options": [
                { "value": "ltx2_22B_distilled", "label": "LTX Video 2.3 Distilled (22B)" },
                { "value": "ltx2_22B", "label": "LTX Video 2.3 (22B)" },
                { "value": "ltx2_19B", "label": "LTX Video 2.0 (19B)" },
                { "value": "t2v", "label": "Wan 2.1 T2V (14B)" },
                { "value": "t2v_1.3B", "label": "Wan 2.1 T2V (1.3B)" },
                { "value": "i2v", "label": "Wan 2.1 I2V 480p" },
                { "value": "i2v_720p", "label": "Wan 2.1 I2V 720p" },
                { "value": "t2v_2_2", "label": "Wan 2.2 T2V" },
                { "value": "hunyuan_t2v", "label": "Hunyuan Video T2V" }
            ],
            "description": "Model for Wan2GP video generation",
            "showWhen": { "apiFormat": ["wan2gp"] }
        },
        {
            "id": "wan2gpDuration",
            "name": "Duration (seconds)",
            "type": "number",
            "default": 5,
            "min": 1,
            "max": 60,
            "description": "Video duration in seconds",
            "showWhen": { "apiFormat": ["wan2gp"] }
        },
        {
            "id": "wan2gpSteps",
            "name": "Steps",
            "type": "number",
            "default": 8,
            "min": 1,
            "max": 100,
            "description": "Number of inference steps",
            "showWhen": { "apiFormat": ["wan2gp"] }
        },
        {
            "id": "endpoint",
            "name": "Endpoint",
            "type": "string",
            "default": "",
            "placeholder": "Use default",
            "description": "Server URL (ComfyUI or Wan2GP)"
        },
        {
            "id": "comfyWorkflow",
            "name": "Workflow JSON",
            "type": "json",
            "default": "",
            "hidden": true
        },
        {
            "id": "comfyWorkflowName",
            "name": "Workflow Name",
            "type": "string",
            "default": "",
            "hidden": true
        },
        {
            "id": "comfyPrimaryPromptNodeId",
            "name": "Prompt Node ID",
            "type": "string",
            "default": "",
            "hidden": true
        },
        {
            "id": "comfyImageInputConfigs",
            "name": "Image Input Configs",
            "type": "json",
            "default": [],
            "hidden": true
        },
        {
            "id": "comfySeedMode",
            "name": "Seed Mode",
            "type": "string",
            "default": "random",
            "hidden": true
        },
        {
            "id": "comfyFixedSeed",
            "name": "Fixed Seed",
            "type": "number",
            "default": null,
            "hidden": true
        },
        {
            "id": "comfyAllImageNodeIds",
            "name": "All Image Node IDs",
            "type": "json",
            "default": [],
            "hidden": true
        },
        {
            "id": "comfyFrameCount",
            "name": "Frame Count",
            "type": "number",
            "default": null,
            "placeholder": "121",
            "description": "Number of frames to generate (overrides workflow)"
        },
        {
            "id": "comfyWidth",
            "name": "Width",
            "type": "number",
            "default": null,
            "placeholder": "1280",
            "description": "Video width in pixels (overrides workflow)"
        },
        {
            "id": "comfyHeight",
            "name": "Height",
            "type": "number",
            "default": null,
            "placeholder": "720",
            "description": "Video height in pixels (overrides workflow)"
        },
        {
            "id": "comfyFrameRate",
            "name": "Frame Rate",
            "type": "number",
            "default": null,
            "placeholder": "24",
            "description": "Frames per second (overrides workflow)"
        }
    ],
    "compiler": {
        "customHandler": true,
        "async": true,
        "abortable": true,
        "statusTracking": true
    },
    "ui": {
        "width": 280,
        "resizable": false
    }
}