{
  "id": "browser_request",
  "name": "Browser Request",
  "description": "Make HTTP requests with full header control.",
  "doc": "Make HTTP/HTTPS requests to APIs and websites.\n\nMethods: GET, POST, PUT, DELETE, PATCH\n\nBody Types:\n• None - no body (GET requests)\n• Form (URL encoded) - form submissions\n• JSON - API requests with JSON payload\n• Multipart - file uploads\n• Raw - custom body content\n\nResponse Formats:\n• HTML - web page content\n• JSON - parsed JSON object\n• Text - raw text response\n• Full - includes headers and status code\n\nLocal Network:\nEnable 'Allow Local Network' for localhost APIs like Ollama, ComfyUI, etc.",
  "icon": "zap",
  "color": "cyan",
  "tags": [
    "http",
    "request",
    "fetch",
    "api"
  ],
  "flowplan": {
    "stepTypes": [
      "http_request",
      "browser_request"
    ],
    "fieldMapping": {
      "url": "url",
      "method": "method",
      "body": "body",
      "headers": "headers"
    },
    "defaults": {
      "method": "GET"
    },
    "templateFields": [
      "url",
      "body"
    ],
    "inputHandleMapping": {
      "url": "url"
    }
  },
  "inputs": [
    {
      "id": "session",
      "name": "Session",
      "type": "object",
      "position": "left",
      "description": "Browser session (optional)"
    },
    {
      "id": "url",
      "name": "URL",
      "type": "string",
      "position": "left",
      "description": "URL to request"
    }
  ],
  "outputs": [
    {
      "id": "response",
      "name": "Response",
      "type": "object",
      "position": "right",
      "description": "Response object with body, headers, status"
    }
  ],
  "properties": [
    {
      "id": "bodyType",
      "name": "Body Type",
      "type": "select",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "form_urlencoded",
          "label": "Form (URL encoded)"
        },
        {
          "value": "json",
          "label": "JSON"
        },
        {
          "value": "multipart",
          "label": "Multipart Format"
        },
        {
          "value": "raw",
          "label": "Raw"
        }
      ],
      "description": "Type of request body"
    },
    {
      "id": "responseFormat",
      "name": "Response Format",
      "type": "select",
      "default": "html",
      "options": [
        {
          "value": "html",
          "label": "HTML"
        },
        {
          "value": "json",
          "label": "JSON"
        },
        {
          "value": "text",
          "label": "Text"
        },
        {
          "value": "full",
          "label": "Full (with headers)"
        }
      ],
      "description": "Expected response format"
    },
    {
      "id": "method",
      "name": "Method",
      "type": "select",
      "default": "GET",
      "options": [
        {
          "value": "GET",
          "label": "GET"
        },
        {
          "value": "POST",
          "label": "POST"
        },
        {
          "value": "PUT",
          "label": "PUT"
        },
        {
          "value": "DELETE",
          "label": "DELETE"
        },
        {
          "value": "PATCH",
          "label": "PATCH"
        }
      ]
    },
    {
      "id": "headers",
      "name": "Headers",
      "type": "textarea",
      "default": "",
      "description": "Custom headers (JSON format)",
      "rows": 3
    },
    {
      "id": "body",
      "name": "Body",
      "type": "textarea",
      "default": "",
      "description": "Request body",
      "rows": 3
    },
    {
      "id": "allowLocalNetwork",
      "name": "Allow Local Network",
      "type": "boolean",
      "default": false,
      "description": "Allow requests to localhost and private IPs (e.g., for ComfyUI, Ollama)"
    },
    {
      "id": "followRedirects",
      "name": "Follow Redirects",
      "type": "boolean",
      "default": true,
      "description": "Follow HTTP redirects",
      "advanced": true
    },
    {
      "id": "maxRedirects",
      "name": "Max Redirects",
      "type": "number",
      "default": 5,
      "min": 0,
      "max": 20,
      "description": "Maximum number of redirects to follow",
      "advanced": true
    },
    {
      "id": "waitForSelector",
      "name": "Wait For Selector",
      "type": "string",
      "default": "",
      "placeholder": ".content-loaded",
      "description": "CSS selector to wait for (WebView mode)",
      "advanced": true
    },
    {
      "id": "waitTimeout",
      "name": "Wait Timeout (ms)",
      "type": "number",
      "default": 30000,
      "min": 0,
      "description": "Timeout for waiting operations",
      "advanced": true
    }
  ],
  "compiler": {
    "template": "{{await}}Browser.request({{input.url}}, {{prop.method.raw}}, {{prop.headers.raw}}, {{prop.body}}, {{input.session}}, \"{{nodeId}}\", {{prop.allowLocalNetwork}})",
    "async": true,
    "abortable": true,
    "statusTracking": true
  },
  "ui": {
    "width": 320,
    "resizable": true
  }
}