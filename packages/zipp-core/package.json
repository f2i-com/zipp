{
  "name": "zipp-core",
  "version": "1.0.0",
  "description": "Shared core engine for Zipp workflow builder (compiler, runtime, types)",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/src/compiler.js",
      "types": "./dist/src/compiler.d.ts"
    },
    "./runtime": {
      "import": "./dist/src/runtime.js",
      "types": "./dist/src/runtime.d.ts"
    },
    "./types": {
      "import": "./dist/src/types.js",
      "types": "./dist/src/types.d.ts"
    },
    "./modules/*/ui": {
      "import": "./modules/*/ui/index.ts",
      "types": "./modules/*/ui/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "formlogic-lang": "file:../../formlogic-rust/dist-wasm",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@monaco-editor/react": ">=4",
    "@types/react": ">=18",
    "@xyflow/react": ">=12",
    "react": ">=18",
    "zipp-ui-components": "*"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    },
    "@monaco-editor/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "zipp-ui-components": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "zipp",
    "workflow",
    "engine",
    "compiler",
    "runtime"
  ],
  "license": "Apache-2.0"
}
