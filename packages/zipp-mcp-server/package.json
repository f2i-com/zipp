{
  "name": "zipp-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Zipp workflow automation - enables Claude to create, run, and debug workflows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zipp-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "node --inspect dist/index.js"
  },
  "keywords": [
    "mcp",
    "claude",
    "zipp",
    "workflow",
    "automation"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
